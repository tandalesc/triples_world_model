{
    "model_type": "io",
    "profile": "mini",
    "d_model": 64,
    "max_triples": 12,
    "text_compressor_layers": 3,
    "text_expander_layers": 3,
    "max_text_tokens": 64,
    "dropout": 0.1,
    "alpha_min": 0.01,
    "vae": true,
    "data_dir": "data/webnlg_multi",
    "tokenizer_path": "data/webnlg_multi/shared_bpe_tokenizer.json",
    "out_dir": "results/test_snapshot",
    "batch_size": 64,
    "denoise_steps": 5,
    "aux_ce_weight": 0.1,
    "length_weight": 0.1,
    "kl_weight": 0.001,
    "kl_anneal_epochs": 50,
    "log_every": 10,
    "diagnostic_every": 100,
    "snapshot_every": 2,
    "stages": [
        {
            "name": "io",
            "dataset": "identity",
            "lr": 3e-4,
            "max_examples": 2000,
            "phases": [
                {"t_min": 0.5, "t_max": 1.0, "epochs": 200, "patience": 0}
            ]
        }
    ],
    "device": "mps"
}
