{
    "model_type": "dynamics",
    "profile": "mini",
    "d_model": 64,
    "max_triples": 12,
    "text_compressor_layers": 3,
    "text_expander_layers": 3,
    "dynamics_layers": 4,
    "max_text_tokens": 64,
    "dropout": 0.1,
    "alpha_min": 0.01,
    "vae": true,
    "data_dir": "data/webnlg_multi",
    "tokenizer_path": "data/webnlg_multi/shared_bpe_tokenizer.json",
    "out_dir": "results/v27_joint_qa_lenfix",
    "batch_size": 128,
    "denoise_steps": 10,
    "aux_ce_weight": 0.1,
    "length_weight": 0.1,
    "kl_weight": 0.001,
    "kl_anneal_epochs": 100,
    "spectral_weight": 0.1,
    "bn_role_weights": [1.0, 1.0, 2.0],
    "detach_dynamics_expander": false,
    "log_every": 10,
    "diagnostic_every": 50,
    "snapshot_every": 10,
    "stages": [
        {
            "name": "dynamics",
            "dataset": "qa",
            "pretrained": "results/v25_clean_conditioning/joint_io_phase2/model_best.pt",
            "lr": 1e-4,
            "max_examples": 15000,
            "phases": [
                {"t_min": 0.4, "t_max": 1.0, "lr": 1e-4, "epochs": 800, "patience": 200, "metric": "tok_acc"}
            ]
        }
    ],
    "device": "cuda"
}
