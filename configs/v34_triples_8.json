{
    "model_type": "dynamics",
    "profile": "micro",
    "d_model": 32,
    "max_triples": 8,
    "text_compressor_layers": 2,
    "text_expander_layers": 2,
    "dynamics_layers": 2,
    "max_text_tokens": 64,
    "dropout": 0.1,
    "alpha_min": 0.01,
    "vae": false,
    "data_dir": "data/webnlg_multi",
    "tokenizer_path": "data/webnlg_multi/shared_bpe_tokenizer.json",
    "out_dir": "results/v34_triples_8",
    "batch_size": 256,
    "denoise_steps": 10,
    "aux_ce_weight": 0.1,
    "length_weight": 0.25,
    "kl_weight": 0.0,
    "kl_anneal_epochs": 0,
    "spectral_weight": 0.1,
    "bn_role_weights": [1.0, 1.0, 2.0],
    "detach_dynamics_expander": false,
    "log_every": 10,
    "diagnostic_every": 50,
    "snapshot_every": 10,
    "stages": [
        {
            "name": "joint_io",
            "dataset": "identity",
            "joint": true,
            "lr": 3e-4,
            "max_examples": 30000,
            "phases": [
                {"t_min": 0.5, "t_max": 1.0, "epochs": 600, "patience": 200},
                {"t_min": 0.3, "t_max": 1.0, "epochs": 600, "patience": 200, "metric": "exact"}
            ]
        },
        {
            "name": "dynamics",
            "dataset": "qa",
            "lr": 1e-4,
            "max_examples": 15000,
            "phases": [
                {"t_min": 0.3, "t_max": 1.0, "lr": 1e-4, "epochs": 800, "patience": 200, "metric": "tok_acc"}
            ]
        }
    ],
    "device": "cuda"
}
