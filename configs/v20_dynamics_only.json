{
    "model_type": "dynamics",
    "profile": "mini",
    "d_model": 64,
    "max_triples": 12,
    "text_compressor_layers": 3,
    "text_expander_layers": 3,
    "dynamics_layers": 4,
    "max_text_tokens": 64,
    "dropout": 0.1,
    "alpha_min": 0.01,
    "data_dir": "data/webnlg_multi",
    "tokenizer_path": "data/webnlg_multi/shared_bpe_tokenizer.json",
    "out_dir": "results/v20_dyn",
    "batch_size": 128,
    "denoise_steps": 10,
    "aux_ce_weight": 0.1,
    "length_weight": 0.1,
    "bn_role_weights": [1.0, 1.0, 2.0],
    "detach_dynamics_expander": true,
    "role_prior_weight": 0.01,
    "log_every": 10,
    "diagnostic_every": 50,
    "stages": [
        {
            "name": "mode_warmup",
            "dataset": "mode_warmup",
            "freeze": ["compressor", "expander"],
            "pretrained": "results/v20_mini64/io_phase1/model_best.pt",
            "max_examples": 15000,
            "phases": [
                {"t_min": 0.0, "t_max": 1.0, "lr": 1e-3, "epochs": 200, "patience": 50}
            ]
        },
        {
            "name": "dynamics",
            "dataset": "qa",
            "freeze": ["compressor", "expander"],
            "max_examples": 15000,
            "phases": [
                {"t_min": 0.0, "t_max": 1.0, "lr": 1e-3, "epochs": 800, "patience": 150}
            ]
        }
    ],
    "device": "cuda:1"
}
